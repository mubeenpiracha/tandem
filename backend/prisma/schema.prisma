generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            String         @id @default(uuid())
  slackTeamId   String         @unique @map("slack_team_id")
  slackTeamName String         @map("slack_team_name")
  slackBotToken String         @map("slack_bot_token")
  isActive      Boolean        @default(true) @map("is_active")
  installedAt   DateTime       @default(now()) @map("installed_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  slackMessages SlackMessage[]
  users         User[]

  @@map("workspaces")
}

model User {
  id              String           @id @default(uuid())
  email           String
  slackUserId     String           @map("slack_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  timezone        String           @default("UTC")
  status          UserStatus       @default(ACTIVE)
  workspaceId     String           @map("workspace_id")
  googleToken     GoogleToken?
  slackToken      SlackToken?
  tasks           Task[]
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workPreferences WorkPreferences?

  @@unique([email, workspaceId])
  @@unique([slackUserId, workspaceId])
  @@map("users")
}

model Task {
  id                String         @id @default(uuid())
  userId            String         @map("user_id")
  title             String
  description       String?
  dueDate           DateTime?      @map("due_date")
  estimatedDuration Int            @map("estimated_duration")
  importance        TaskImportance @default(MEDIUM)
  derivedUrgency    TaskUrgency    @default(MEDIUM) @map("derived_urgency")
  status            TaskStatus     @default(PENDING)
  slackMessageId    String?        @map("slack_message_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  calendarEvent     CalendarEvent?
  slackMessage      SlackMessage?  @relation(fields: [slackMessageId], references: [id])
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model CalendarEvent {
  id            String   @id @default(uuid())
  taskId        String   @unique @map("task_id")
  googleEventId String   @unique @map("google_event_id")
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

model SlackMessage {
  id               String        @id @default(uuid())
  slackMessageId   String        @map("slack_message_id")
  slackChannelId   String        @map("slack_channel_id")
  slackThreadId    String?       @map("slack_thread_id")
  status           MessageStatus @default(DETECTED)
  messageTimestamp DateTime      @map("message_timestamp")
  processedAt      DateTime?     @map("processed_at")
  workspaceId      String        @map("workspace_id")
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks            Task[]

  @@unique([slackMessageId, workspaceId])
  @@map("slack_messages")
}

model WorkPreferences {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  weeklyHours Json     @map("weekly_hours")
  breakTimes  Json     @map("break_times")
  timezone    String   @default("UTC")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("work_preferences")
}

model SlackToken {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("slack_tokens")
}

model GoogleToken {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_tokens")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TaskStatus {
  PENDING
  CONFIRMED
  SCHEDULED
  COMPLETED
  DISMISSED
}

enum TaskImportance {
  LOW
  MEDIUM
  HIGH
}

enum TaskUrgency {
  LOW
  MEDIUM
  HIGH
}

enum MessageStatus {
  DETECTED
  PROCESSED
  IGNORED
  ERROR
}
