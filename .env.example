# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=
PORT=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# docker-compose default: postgresql://tandem:tandem@localhost:5432/tandem_dev
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string
# docker-compose default: redis://localhost:6379
REDIS_URL=

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM token encryption at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY_CURRENT=
# Previous key — used during key rotation only (leave blank if not rotating)
ENCRYPTION_KEY_PREVIOUS=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secret for signing short-lived access tokens
# Generate with: openssl rand -base64 64
JWT_SECRET=

# ─── Slack ────────────────────────────────────────────────────────────────────
# From https://api.slack.com/apps → Basic Information → App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Bot token (xoxb-...) — used for sending DMs and updating the Home Tab
SLACK_BOT_TOKEN=
# App-level token (xapp-...) — required for Socket Mode
SLACK_APP_TOKEN=

# ─── Google ───────────────────────────────────────────────────────────────────
# From https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for task classification via gpt-4o-mini
OPENAI_API_KEY=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Prefix with VITE_ to expose to the browser bundle
# Base URL of the backend API (e.g., http://localhost:3001)
VITE_API_URL=
