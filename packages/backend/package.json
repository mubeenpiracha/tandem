{
  "name": "@tandem/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.20.0",
    "@slack/bolt": "^3.21.0",
    "@tandem/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^128.0.0",
    "jose": "^6.2.2",
    "openai": "^4.57.0",
    "resend": "^6.10.0",
    "zod": "^3.23.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
