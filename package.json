{
  "name": "tandem",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' run dev",
    "build": "pnpm --filter '@tandem/shared' run build && pnpm --parallel --filter '@tandem/backend' --filter '@tandem/frontend' run build",
    "lint": "pnpm --parallel --filter './packages/*' run lint",
    "type-check": "pnpm --parallel --filter './packages/*' run type-check",
    "test": "pnpm --parallel --filter './packages/*' run test",
    "db:migrate": "pnpm --filter @tandem/backend run db:migrate",
    "db:reset": "pnpm --filter @tandem/backend run db:reset",
    "db:studio": "pnpm --filter @tandem/backend run db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  }
}
